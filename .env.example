# Copy this file to .env and fill in your keys.
# The app works without API keys in Browser + None-translation mode.

PORT=5001

# Required for OpenAI Whisper transcription and GPT-4o-mini translation
OPENAI_API_KEY=sk-...

# Required for AssemblyAI real-time transcription
ASSEMBLYAI_API_KEY=...

# Required for Claude Haiku translation
ANTHROPIC_API_KEY=sk-ant-...

# Inject artificial latency on API routes and WebSocket chunks to simulate
# mobile network conditions during local development (milliseconds).
# 0 = disabled. Recommended test value: 1500 (slow 4G + mobile CPU overhead).
SIMULATE_LATENCY_MS=0
