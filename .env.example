# Copy this file to .env and fill in your keys.
# The app works without API keys in Browser + None-translation mode.

PORT=5001

# Required for OpenAI Whisper transcription and GPT-4o-mini translation
OPENAI_API_KEY=sk-...

# Required for AssemblyAI real-time transcription
ASSEMBLYAI_API_KEY=...

# Required for Claude Haiku translation
ANTHROPIC_API_KEY=sk-ant-...
